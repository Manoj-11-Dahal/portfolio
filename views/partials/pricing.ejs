<div class="pricing-grid">
  <% pricing.forEach((plan, index) => { %>
    <article class="pricing-card panel <%= index === 1 ? 'featured-plan' : '' %>">
      <% if (index === 1) { %><span class="plan-badge">Recommended</span><% } %>
      <h3><%= plan.name %></h3>
      <strong class="price"><%= plan.price %></strong>
      <p><%= plan.description %></p>
      <ul>
        <% plan.features.forEach(feature => { %><li><%= feature %></li><% }) %>
      </ul>
      <a class="btn ghost" href="#contact">Start with <%= plan.name %></a>
    </article>
  <% }) %>
</div>
