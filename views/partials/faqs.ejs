<div class="faq-list">
  <% faqs.forEach((faq, index) => { %>
    <details class="faq-item panel" <%= index === 0 ? 'open' : '' %>>
      <summary>
        <span><%= String(index + 1).padStart(2, '0') %></span>
        <strong><%= faq.question %></strong>
      </summary>
      <p><%= faq.answer %></p>
    </details>
  <% }) %>
</div>
